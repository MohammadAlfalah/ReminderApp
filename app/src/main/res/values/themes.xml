<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.MyFApp" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Your brand colors -->
        <item name="colorPrimary">@color/primaryColor</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/accentColor</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="colorSurface">@color/backgroundColor</item>
        <item name="colorOnBackground">@color/textPrimary</item>
        <item name="colorOnSurface">@color/textPrimary</item>




        <!-- Optional: override corner radius globally -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.MyFApp.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MyFApp.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.MyFApp.Large</item>
    </style>

    <style name="Theme.MyFApp" parent="Base.Theme.MyFApp" />

    <!-- Custom shape appearance matching Material 2 -->
    <style name="ShapeAppearance.MyFApp.Small" parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">4dp</item>
    </style>

    <style name="ShapeAppearance.MyFApp.Medium" parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">4dp</item>
    </style>

    <style name="ShapeAppearance.MyFApp.Large" parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">4dp</item>
    </style>
</resources>
