        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.MyFApp.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.MyFApp.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.MyFApp.Large</item>
